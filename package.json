{
  "name": "payedpos-automation",
  "version": "1.0.0",
  "description": "Production-ready foundation for Playwright-based PayedPOS automation",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "server": "node src/server.js",
