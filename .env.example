PAYEDPOS_BASE_URL=https://your-payedpos-instance.example.com
PAYEDPOS_LOGIN_PATH=/sign-in
PAYEDPOS_USERNAME=your-username
PAYEDPOS_PASSWORD=your-password
PAYEDPOS_HEADLESS=true
PAYEDPOS_VIEWPORT=1440,900
PAYEDPOS_TIMEOUT=30000
PAYEDPOS_MAX_RETRIES=2
PAYEDPOS_STORAGE_STATE_PATH=storage/auth-state.json
PAYEDPOS_OUTPUT_DIR=output
PAYEDPOS_SNAPSHOT_DIR=snapshots
PAYEDPOS_LOG_DIR=logs

# --- Next.js dashboard (this repo's web app, deployed on Vercel) ---
# URL of the always-on host running `npm run automation:server` (src/server.js).
# Vercel functions can't run a persistent Playwright browser, so the
# automation server must be deployed separately (Railway, Fly.io, a VPS,
# Docker, etc.) and this dashboard talks to it over HTTP.
# This is now a fallback path - GitHub Actions (below) is the primary way
# to run the automation. Leave everything below unset to run the
# dashboard against demo data only.
AUTOMATION_API_URL=

# --- GitHub Actions automation (primary path - see
# .github/workflows/automation.yml and docs/github-actions-automation.md)
#
# These four are set on VERCEL (Project Settings -> Environment
# Variables), NOT as GitHub repo secrets - they're what the Next.js app
# uses to trigger the workflow on your behalf.
#
# A GitHub Personal Access Token (fine-grained, scoped to this repo only)
# with "Actions: Read and write" permission. Never exposed to the
# browser - only read server-side in lib/github-actions-client.ts.
GITHUB_TOKEN=
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=payedpos-automation
# Optional - defaults shown:
GITHUB_WORKFLOW_FILE=automation.yml
GITHUB_WORKFLOW_REF=main

# Shared secret the dashboard's "Run" button and any external caller must
# present to POST /api/refresh. Generate with: openssl rand -hex 32
REFRESH_TRIGGER_SECRET=

# Shared secret the GitHub Actions workflow presents to POST /api/ingest.
# Must match INGEST_API_SECRET below exactly (that one's a GitHub repo
# secret, this one's a Vercel env var - same value, two places).
# Generate with: openssl rand -hex 32
INGEST_API_SECRET=

# Supabase project (see supabase/schema.sql - run that once in the
# Supabase SQL Editor before setting these). Settings -> API in the
# Supabase dashboard for both values. The service_role key bypasses Row
# Level Security by design - never expose it to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------
# Everything below this line are GitHub *repository* secrets (Settings ->
# Secrets and variables -> Actions -> New repository secret), NOT Vercel
# environment variables. The workflow reads these directly; they are
# never seen by the Next.js app.
#
#   PAYEDPOS_BASE_URL       (same value as above)
#   PAYEDPOS_LOGIN_PATH     (optional, same value as above)
#   PAYEDPOS_USERNAME       (same value as above)
#   PAYEDPOS_PASSWORD       (same value as above)
#   INGEST_API_URL          e.g. https://your-app.vercel.app/api/ingest
#   INGEST_API_SECRET       (same value as the Vercel one above)
# ---------------------------------------------------------------------
